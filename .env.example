# Copy to .env.local — never commit secrets

# ── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ── Razorpay client-side key (publishable; never put secret in Vite) ────────
VITE_RAZORPAY_KEY_ID=rzp_test_...

# ── Next.js admin/API endpoint ───────────────────────────────────────────────
# Local dev: http://localhost:3001
# Prod:      https://coco36-next.vercel.app (or https://admin.coco36.com)
VITE_API_URL=https://coco36-next.vercel.app

# ── AI Recipe Consultant (optional — for /recipes page) ─────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
APP_URL=http://localhost:3000
